{
  "name": "maptour",
  "version": "1.5.1",
  "description": "Embeddable map tour player for static websites",
  "license": "MIT",
  "type": "module",
  "main": "dist/maptour.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src",
    "dev:authoring": "vite --config vite.authoring.config.ts",
    "build:authoring": "vite build --config vite.authoring.config.ts",
    "build:site": "npm run build && npm run build:authoring && node scripts/build-site.mjs"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "js-yaml": "^4.1.0",
    "leaflet": "^1.9.4",
    "marked": "^12.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/js-yaml": "^4.0.9",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^9.0.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  }
}
